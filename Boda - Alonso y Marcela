<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alonso & Marcela</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Montserrat:wght@300;400&display=swap" rel="stylesheet">

<style>
body{
margin:0;
font-family:'Montserrat', sans-serif;
background:#fdfbf7;
color:#333;
overflow-x:hidden;
}

/* SOBRE */
#cover{
position:fixed;
width:100%;
height:100vh;
background:#fff;
display:flex;
justify-content:center;
align-items:center;
z-index:999;
cursor:pointer;
transition:1s;
}

#cover h2{
font-family:'Playfair Display', serif;
letter-spacing:2px;
}

/* HERO */
.hero{
height:100vh;
background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
url('foto_portada.jpg');
background-size:cover;
background-position:center;
color:white;
display:flex;
flex-direction:column;
justify-content:center;
text-align:center;
opacity:0;
transition:2s;
}

.hero.show{opacity:1;}

.hero h1{
font-family:'Playfair Display', serif;
font-size:3em;
}

/* SECCIONES */
.section{
padding:70px 20px;
text-align:center;
}

h2{
font-family:'Playfair Display', serif;
}

/* BOTÓN */
.button{
padding:12px 30px;
border-radius:30px;
background:#d4af37;
color:white;
text-decoration:none;
display:inline-block;
margin-top:20px;
}

/* GALERÍA */
.gallery{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:15px;
}

.gallery img{
width:260px;
border-radius:12px;
transition:0.4s;
}

.gallery img:hover{
transform:scale(1.05);
}

/* FORM */
input, select, textarea{
width:90%;
max-width:320px;
padding:12px;
margin:10px;
border-radius:8px;
border:1px solid #ccc;
}

/* CONTADOR */
#contador{
margin-top:20px;
font-size:1.2em;
}

/* MÚSICA */
.music{
position:fixed;
bottom:20px;
right:20px;
background:#d4af37;
color:white;
padding:10px;
border-radius:50%;
cursor:pointer;
}

footer{
padding:40px;
text-align:center;
}
</style>
</head>

<body>

<!-- SOBRE -->
<div id="cover" onclick="abrirInvitacion()">
<h2>Abrir invitación</h2>
</div>

<!-- MÚSICA -->
<div class="music" onclick="toggleMusic()">♫</div>
<audio id="musica" loop>
<source src="https://www.bensound.com/bensound-music/bensound-romantic.mp3">
</audio>

<!-- HERO -->
<section class="hero" id="hero">
<h1>Alonso Fuentes & Marcela David</h1>
<p>Con la bendición de Dios</p>
<p>Te invitamos a celebrar nuestro matrimonio</p>

<h2>28 de Junio 2026 – 5:00 PM</h2>

<div id="contador"></div>
</section>

<!-- VERSÍCULO -->
<section class="section">
<h2>Versículo</h2>
<p>"Y sobre todas estas cosas vestíos de amor, que es el vínculo perfecto."<br>Colosenses 3:14</p>
</section>

<!-- UBICACIÓN -->
<section class="section">
<h2>Ubicación</h2>
<p>Ipuc Las Margaritas</p>
<p>Cl. 62cc #106a75, Santa Margarita</p>

<a class="button" href="https://maps.app.goo.gl/Q1Je8m896TjudKEd9" target="_blank">
Ver ubicación
</a>

<p>Agradecemos tu puntualidad</p>
</section>

<!-- GALERÍA -->
<section class="section">
<h2>Momentos</h2>

<div class="gallery">
<img src="foto1.jpg">
<img src="foto2.jpg">
<img src="foto3.jpg">
<img src="foto4.jpg">
</div>
</section>

<!-- REGALOS -->
<section class="section">
<h2>Regalos</h2>
<p>Lluvia de sobres ✉️</p>
</section>

<!-- RSVP -->
<section class="section">
<h2>Confirmar asistencia</h2>

<form onsubmit="enviarWhatsApp(event)">
<input type="text" id="nombre" placeholder="Nombre completo" required>

<select id="asistencia">
<option>Sí asistiré</option>
<option>No podré asistir</option>
</select>

<textarea id="mensaje" placeholder="Mensaje opcional"></textarea>

<button class="button">Confirmar asistencia</button>
</form>
</section>

<footer>
Gracias por acompañarnos en este día que Dios ha preparado 💛
</footer>

<script>
// ABRIR INVITACIÓN
function abrirInvitacion(){
document.getElementById("cover").style.display="none";
document.getElementById("hero").classList.add("show");
document.getElementById("musica").play();
}

// CONTADOR
let fecha = new Date("June 28, 2026 17:00:00").getTime();

setInterval(()=>{
let ahora = new Date().getTime();
let diff = fecha - ahora;

let d = Math.floor(diff/(1000*60*60*24));
let h = Math.floor((diff%(1000*60*60*24))/(1000*60*60));
let m = Math.floor((diff%(1000*60*60))/(1000*60));

document.getElementById("contador").innerHTML =
`Faltan ${d} días • ${h}h • ${m}m`;
},1000);

// WHATSAPP
function enviarWhatsApp(e){
e.preventDefault();

let nombre = document.getElementById("nombre").value;
let asistencia = document.getElementById("asistencia").value;
let mensaje = document.getElementById("mensaje").value;

let texto = `Hola, soy ${nombre}. Confirmo: ${asistencia}. ${mensaje}`;

window.open(`https://wa.me/573208822116?text=${encodeURIComponent(texto)}`);
}

// MÚSICA
function toggleMusic(){
let m = document.getElementById("musica");
m.paused ? m.play() : m.pause();
}
</script>

</body>
</html>
